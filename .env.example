# Smarty US Street API credentials (free trial at https://www.smarty.com)
# Get these from your Smarty account dashboard
SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=

# Username/password authentication
# AUTH_SECRET: long random string used to sign session cookies
AUTH_SECRET=dev-change-me-to-a-long-random-string

# AUTH_USERS: JSON array of allowed accounts (keep quotes so special chars are safe)
# Example:
# AUTH_USERS='[{"username":"admin","password":"choose-a-strong-password","name":"Admin"}]'
AUTH_USERS='[{"username":"admin","password":"changeme","name":"Admin"}]'
